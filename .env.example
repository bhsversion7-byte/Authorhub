VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
VITE_PUBLIC_SITE_URL=https://www.authorhub.cn
CAPTCHA_SECRET=replace-with-a-long-private-random-string

# Optional: Cloudflare Turnstile, an additive bot-detection widget on top of
# the numeric captcha above (see api/verify-turnstile.js). Works without any
# DNS/CDN change - Turnstile is a standalone widget service, not tied to
# using Cloudflare as your DNS/proxy provider. Leave both unset to keep the
# app exactly as it is today; set both together (then redeploy) to turn it
# on - setting only one is a misconfiguration the server rejects rather than
# silently ignores.
VITE_TURNSTILE_SITE_KEY=replace-with-turnstile-site-key
TURNSTILE_SECRET_KEY=replace-with-turnstile-secret-key

# Optional: one-off update email sender.
# Keep real values in local .env only. Do not commit secrets.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
AUTHORHUB_EMAIL_FROM=AuthorHub <updates@authorhub.cn>
AUTHORHUB_FEEDBACK_EMAIL=your-feedback-email@example.com
AUTHORHUB_EMAIL_SUBJECT=AuthorHub 更新说明
AUTHORHUB_EMAIL_CONFIRM=SEND_AUTHORHUB_UPDATE
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key
